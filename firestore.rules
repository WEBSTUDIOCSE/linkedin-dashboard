rules_version = '2';

/**
 * Firestore Security Rules
 *
 * Principle of least privilege — deny everything by default, then
 * whitelist specific paths with specific conditions.
 *
 * Collections:
 *   uat_users / prod_users — per-user profile documents (keyed by UID)
 *
 * Adjust these rules as new collections are added.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Deny all by default ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── UAT User Profiles ───────────────────────────────────────────────
    match /uat_users/{userId} {
      // Users can only read/write their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    // Cap document size to 20 KB to prevent cost bloat
                    && request.resource.data.size() < 20000;
      allow update: if request.auth != null && request.auth.uid == userId
                    // Cap document size to 20 KB to prevent cost bloat
                    && request.resource.data.size() < 20000
                    // Prevent users from changing immutable fields
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['uid', 'createdAt', 'environment']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── PROD User Profiles ──────────────────────────────────────────────
    match /prod_users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.size() < 20000;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.size() < 20000
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['uid', 'createdAt', 'environment']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Users Collection ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Posts Collection ────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
